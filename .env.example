# 로그인 게이트용 HMAC 서명 시크릿 (32자 이상 랜덤 문자열 권장).
# 생성 예: `openssl rand -base64 48`
# Vercel 대시보드 → Project → Settings → Environment Variables 에 등록.
AUTH_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# 로그인 비밀번호. 실 운영 시 강한 값으로 교체.
# 미설정 시 기본값 "cosmax-dev" (로컬 개발 전용).
LOGIN_PASSWORD="cosmax-dev"
